VITE_APP_NAME=TORAM
VITE_APP_HIK_DEVICE_BASE_URL=
VITE_APP_HIKCENTRAL_BASE_URL=
# Solo npm run dev: si el proxy da 502, prueba la misma URL o otra (p. ej. http://127.0.0.1:PUERTO)
# VITE_APP_HIK_PROXY_TARGET=https://127.0.0.1
VITE_APP_HIKCENTRAL_APP_KEY=
VITE_APP_HIKCENTRAL_APP_SECRET=
VITE_APP_API_MODE=mock

# Modo real: índice del departamento "Visitas" en HikCentral (copiar desde el cliente web)
VITE_APP_HIK_ORG_INDEX_CODE=
VITE_APP_HIK_DEPARTMENT_NAME=Visitas

# Códigos de nivel de acceso en HikCentral (basico / premium / VIP) — uno por tarifa TORAM
VITE_APP_HIK_ACCESS_BASE=
VITE_APP_HIK_ACCESS_PREMIUM=
VITE_APP_HIK_ACCESS_VIP=

# Opcional: si tu OpenAPI usa otras rutas
# VITE_APP_HIK_ENDPOINT_PERSON_ADD=/artemis/api/resource/v1/person/single/add
# VITE_APP_HIK_ENDPOINT_ACCESS_BIND=/artemis/api/resource/v1/person/single/addAccessLevel

# Opcional: JSON extra fusionado al cuerpo del alta de persona
# VITE_APP_HIK_PERSON_EXTRA_JSON={"customField1":"value"}
